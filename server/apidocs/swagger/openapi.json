{
  "openapi": "3.0.3",
  "info": {
    "title": "GCS-Distill API",
    "version": "v0.1.0",
    "description": "GCS-Distill control plane HTTP API documentation."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    { "name": "health", "description": "Service health" },
    { "name": "projects", "description": "Project management" },
    { "name": "datasets", "description": "Dataset management" },
    { "name": "pipelines", "description": "Pipeline management" },
    { "name": "models", "description": "Model management" },
    { "name": "resources", "description": "Worker resource discovery" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "tags": ["projects"],
        "summary": "List projects",
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Paged project list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["projects"],
        "summary": "Create project",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Project" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/ProjectId" }
      ],
      "get": {
        "tags": ["projects"],
        "summary": "Get project",
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          },
          "404": {
            "description": "Project not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["projects"],
        "summary": "Update project",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Project" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["projects"],
        "summary": "Delete project",
        "responses": {
          "200": {
            "description": "Project deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{id}/datasets": {
      "parameters": [
        { "$ref": "#/components/parameters/ProjectId" }
      ],
      "post": {
        "tags": ["datasets"],
        "summary": "Upload dataset file",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/DatasetUploadRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset uploaded successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid upload request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets": {
      "get": {
        "tags": ["datasets"],
        "summary": "List datasets",
        "parameters": [
          { "$ref": "#/components/parameters/ProjectIdQuery" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Paged dataset list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["datasets"],
        "summary": "Create dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Dataset" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/DatasetId" }
      ],
      "get": {
        "tags": ["datasets"],
        "summary": "Get dataset",
        "responses": {
          "200": {
            "description": "Dataset details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["datasets"],
        "summary": "Update dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Dataset" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DatasetResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["datasets"],
        "summary": "Delete dataset",
        "responses": {
          "200": {
            "description": "Dataset deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines": {
      "get": {
        "tags": ["pipelines"],
        "summary": "List pipelines",
        "parameters": [
          { "$ref": "#/components/parameters/ProjectIdQuery" },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Paged pipeline list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PipelineListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["pipelines"],
        "summary": "Create pipeline",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PipelineRun" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PipelineResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/PipelineId" }
      ],
      "get": {
        "tags": ["pipelines"],
        "summary": "Get pipeline",
        "responses": {
          "200": {
            "description": "Pipeline details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PipelineResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/start": {
      "post": {
        "tags": ["pipelines"],
        "summary": "Start pipeline",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" }
        ],
        "responses": {
          "200": {
            "description": "Pipeline started",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/cancel": {
      "post": {
        "tags": ["pipelines"],
        "summary": "Cancel pipeline",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" }
        ],
        "responses": {
          "200": {
            "description": "Pipeline cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/stages": {
      "get": {
        "tags": ["pipelines"],
        "summary": "List pipeline stages",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" }
        ],
        "responses": {
          "200": {
            "description": "Pipeline stages",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StageListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/stages/{stage_id}/logs": {
      "get": {
        "tags": ["pipelines"],
        "summary": "Get complete stage logs",
        "description": "Retrieve the complete log content for a specific pipeline stage",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" },
          { "$ref": "#/components/parameters/StageId" }
        ],
        "responses": {
          "200": {
            "description": "Stage logs retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LogResponse" }
              }
            }
          },
          "404": {
            "description": "Stage not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/stages/{stage_id}/logs/stream": {
      "get": {
        "tags": ["pipelines"],
        "summary": "Get real-time stage logs",
        "description": "Retrieve the most recent log lines for a specific pipeline stage (suitable for polling)",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" },
          { "$ref": "#/components/parameters/StageId" },
          {
            "name": "tail",
            "in": "query",
            "description": "Number of lines to return from the end of the log",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 10000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Real-time logs retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StreamLogResponse" }
              }
            }
          },
          "404": {
            "description": "Stage not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/pipelines/{id}/stages/{stage_id}/logs/download": {
      "get": {
        "tags": ["pipelines"],
        "summary": "Download stage log file",
        "description": "Download the complete log file for a specific pipeline stage",
        "parameters": [
          { "$ref": "#/components/parameters/PipelineId" },
          { "$ref": "#/components/parameters/StageId" }
        ],
        "responses": {
          "200": {
            "description": "Log file download",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Stage or log file not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/resources/nodes": {
      "get": {
        "tags": ["resources"],
        "summary": "List worker nodes",
        "responses": {
          "200": {
            "description": "Worker nodes",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NodeListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/resources/nodes/{name}": {
      "get": {
        "tags": ["resources"],
        "summary": "Get worker node",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Worker node details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NodeResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/models/student": {
      "get": {
        "tags": ["models"],
        "summary": "List student models",
        "description": "Get all available student models from the configured models directory",
        "responses": {
          "200": {
            "description": "Student model list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StudentModelListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/models/student/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "Model ID (directory name)",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "tags": ["models"],
        "summary": "Get student model",
        "description": "Get details of a specific student model by ID",
        "responses": {
          "200": {
            "description": "Student model details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StudentModelResponse" }
              }
            }
          },
          "404": {
            "description": "Model not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "default": 1, "minimum": 1 }
      },
      "PageSize": {
        "name": "page_size",
        "in": "query",
        "schema": { "type": "integer", "default": 20, "minimum": 1 }
      },
      "ProjectIdQuery": {
        "name": "project_id",
        "in": "query",
        "required": true,
        "schema": { "type": "string" }
      },
      "ProjectId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "DatasetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "PipelineId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "StageId": {
        "name": "stage_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok" }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 200 },
          "message": { "type": "string", "example": "操作成功" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 400 },
          "message": { "type": "string", "example": "请求参数错误" }
        }
      },
      "TeacherModelConfig": {
        "type": "object",
        "properties": {
          "provider_type": { "type": "string", "example": "api", "description": "Provider type: api or local" },
          "model_name": { "type": "string", "example": "gpt-4", "description": "Model name" },
          "endpoint": { "type": "string", "example": "https://api.openai.com/v1/chat/completions", "description": "API endpoint (for api provider)" },
          "api_secret_ref": { "type": "string", "example": "openai_key", "description": "API secret reference (for api provider)" },
          "temperature": { "type": "number", "format": "double", "example": 0.7 },
          "max_tokens": { "type": "integer", "example": 2048 },
          "concurrency": { "type": "integer", "example": 10 },
          "timeout_seconds": { "type": "integer", "example": 60 },
          "extra_params": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "StudentModelConfig": {
        "type": "object",
        "required": ["provider_type", "model_name", "model_path"],
        "properties": {
          "provider_type": { "type": "string", "example": "local", "description": "Must be 'local' - system runs in offline environment" },
          "model_name": { "type": "string", "example": "Qwen2.5-0.5B-Instruct", "description": "Student model name" },
          "model_path": { "type": "string", "example": "/mnt/shared/distill/models/Qwen2.5-0.5B-Instruct", "description": "Required - local model file path" },
          "temperature": { "type": "number", "format": "double", "example": 0.7 },
          "max_tokens": { "type": "integer", "example": 2048 },
          "extra_params": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "EvaluationConfig": {
        "type": "object",
        "properties": {
          "metrics": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["bleu", "rouge", "accuracy"]
          },
          "test_set_ratio": { "type": "number", "format": "double", "example": 0.2 },
          "extra_params": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-project" },
          "name": { "type": "string", "example": "客服问答蒸馏" },
          "description": { "type": "string", "example": "将教师模型蒸馏到轻量学生模型" },
          "business_scenario": { "type": "string", "example": "智能客服" },
          "teacher_model_config": { "$ref": "#/components/schemas/TeacherModelConfig" },
          "student_model_config": { "$ref": "#/components/schemas/StudentModelConfig" },
          "evaluation_config": { "$ref": "#/components/schemas/EvaluationConfig" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-dataset" },
          "project_id": { "type": "string", "example": "uuid-project" },
          "name": { "type": "string", "example": "训练数据集" },
          "description": { "type": "string", "example": "种子或蒸馏数据" },
          "source_type": { "type": "string", "example": "upload" },
          "file_path": { "type": "string", "example": "/mnt/shared/distill/project-a/seeds.jsonl" },
          "record_count": { "type": "integer", "example": 1000 },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "DatasetUploadRequest": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "name": { "type": "string", "example": "real-upload-dataset" },
          "description": { "type": "string", "example": "uploaded file test" },
          "file": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "LoRAConfig": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "example": true },
          "r": { "type": "integer", "example": 8 },
          "alpha": { "type": "integer", "example": 16 },
          "dropout": { "type": "number", "format": "double", "example": 0.05 },
          "target_modules": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "TrainingConfig": {
        "type": "object",
        "properties": {
          "num_train_epochs": { "type": "integer", "example": 3 },
          "per_device_train_batch_size": { "type": "integer", "example": 4 },
          "gradient_accumulation_steps": { "type": "integer", "example": 1 },
          "learning_rate": { "type": "number", "format": "double", "example": 0.00002 },
          "weight_decay": { "type": "number", "format": "double", "example": 0.01 },
          "warmup_ratio": { "type": "number", "format": "double", "example": 0.03 },
          "lr_scheduler_type": { "type": "string", "example": "cosine" },
          "save_steps": { "type": "integer", "example": 100 },
          "logging_steps": { "type": "integer", "example": 10 },
          "max_length": { "type": "integer", "example": 4096 },
          "lora_config": { "$ref": "#/components/schemas/LoRAConfig" }
        }
      },
      "ResourceRequest": {
        "type": "object",
        "properties": {
          "gpu_count": { "type": "integer", "example": 1, "description": "Number of GPUs to use. Set to -1 for all available GPUs." },
          "gpu_device_ids": { "type": "string", "example": "0,1,2", "description": "Comma-separated GPU device IDs (e.g., '0,1,2'). If specified, takes priority over gpu_count." },
          "gpu_type": { "type": "string", "example": "RTX 4090", "description": "GPU type" },
          "memory_gb": { "type": "integer", "example": 32, "description": "Memory in GB" },
          "cpu_cores": { "type": "integer", "example": 8, "description": "Number of CPU cores" }
        }
      },
      "PipelineRun": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-pipeline" },
          "project_id": { "type": "string", "example": "uuid-project" },
          "dataset_id": { "type": "string", "example": "uuid-dataset" },
          "status": { "type": "string", "example": "pending" },
          "current_stage": { "type": "integer", "example": 0 },
          "trigger_mode": { "type": "string", "example": "manual" },
          "training_config": { "$ref": "#/components/schemas/TrainingConfig" },
          "resource_request": { "$ref": "#/components/schemas/ResourceRequest" },
          "error_message": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "StageRun": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-stage" },
          "pipeline_run_id": { "type": "string", "example": "uuid-pipeline" },
          "stage_type": { "type": "string", "example": "teacher_infer" },
          "stage_order": { "type": "integer", "example": 3 },
          "status": { "type": "string", "example": "running" },
          "container_id": { "type": "string" },
          "node_name": { "type": "string" },
          "config_path": { "type": "string" },
          "input_manifest": {
            "type": "object",
